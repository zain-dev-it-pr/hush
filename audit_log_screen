import 'package:flutter/material.dart';

import 'package:hushh/models.dart';
import 'package:hushh/app_theme.dart';
import 'package:hushh/shared_widgets.dart';
class AuditLogScreen extends StatelessWidget {
  const AuditLogScreen({super.key});
  @override
  Widget build(BuildContext context) {
    final entries = List<AuditEntry>.from(SampleData.auditLog)
      ..sort((a, b) => b.timestamp.compareTo(a.timestamp));

    // Group by date
    final grouped = <String, List<AuditEntry>>{};
    for (final entry in entries) {
      final key = _dateKey(entry.timestamp);
      grouped.putIfAbsent(key, () => []).add(entry);
    }

    return Scaffold(
      backgroundColor: AppTheme.bgBase,
      appBar: AppBar(
        title: const Text('Audit Log'),
        actions: [
          IconButton(
            icon: const Icon(Icons.filter_list_rounded),
            onPressed: () {}, // TODO: add filter sheet
            tooltip: 'Filter',
          ),
        ],
      ),
      body: grouped.isEmpty
          ? const EmptyState(
        icon: Icons.receipt_long_outlined,
        title: 'No activity yet',
        subtitle: 'When data is shared or access is revoked, it will appear here.',
      )
          : ListView(
        padding: const EdgeInsets.all(20),
        children: grouped.entries.expand((group) {
          return [
            Padding(
              padding: const EdgeInsets.only(bottom: 10),
              child: SectionHeader(title: group.key),
            ),
            ...group.value.map(
                  (e) => Padding(
                padding: const EdgeInsets.only(bottom: 10),
                child: _AuditEntryCard(entry: e),
              ),
            ),
            const SizedBox(height: 14),
          ];
        }).toList(),
      ),
    );
  }

  String _dateKey(DateTime dt) {
    final now = DateTime.now();
    final diff = now.difference(dt);
    if (diff.inDays == 0) return 'Today';
    if (diff.inDays == 1) return 'Yesterday';
    return '${dt.day}/${dt.month}/${dt.year}';
  }
}

//  Single audit entry card

class _AuditEntryCard extends StatelessWidget {
  const _AuditEntryCard({required this.entry});
  final AuditEntry entry;

  @override
  Widget build(BuildContext context) {
    final (icon, color, actionLabel) = _actionStyle(entry.action);

    return HushhCard(
      child: Row(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          // Action icon
          Container(
            width: 40,
            height: 40,
            decoration: BoxDecoration(
              color: color.withOpacity(0.1),
              shape: BoxShape.circle,
            ),
            child: Icon(icon, color: color, size: 18),
          ),
          const SizedBox(width: 12),
          Expanded(
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  children: [
                    Text(
                      entry.partnerName,
                      style: const TextStyle(
                        fontSize: 14,
                        fontWeight: FontWeight.w600,
                        color: AppTheme.textPrimary,
                      ),
                    ),
                    const SizedBox(width: 6),
                    Container(
                      padding: const EdgeInsets.symmetric(
                          horizontal: 8, vertical: 2),
                      decoration: BoxDecoration(
                        color: color.withOpacity(0.1),
                        borderRadius: BorderRadius.circular(20),
                      ),
                      child: Text(
                        actionLabel,
                        style: TextStyle(
                          fontSize: 10,
                          fontWeight: FontWeight.w600,
                          color: color,
                        ),
                      ),
                    ),
                  ],
                ),
                const SizedBox(height: 4),
                Wrap(
                  spacing: 6,
                  runSpacing: 4,
                  children: entry.fields
                      .map(
                        (f) => Container(
                      padding: const EdgeInsets.symmetric(
                          horizontal: 8, vertical: 3),
                      decoration: BoxDecoration(
                        color: AppTheme.bgCardElevated,
                        borderRadius: BorderRadius.circular(6),
                        border: Border.all(color: AppTheme.border),
                      ),
                      child: Text(
                        f,
                        style: const TextStyle(
                          fontSize: 11,
                          color: AppTheme.textSecondary,
                        ),
                      ),
                    ),
                  )
                      .toList(),
                ),
                const SizedBox(height: 6),
                Text(
                  _formatTimestamp(entry.timestamp),
                  style: AppTheme.caption,
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }

  // Map each action type to an icon, color, and human-readable label
  (IconData, Color, String) _actionStyle(AuditAction action) {
    return switch (action) {
      AuditAction.shared => (
      Icons.share_rounded,
      AppTheme.success,
      'Shared',
      ),
      AuditAction.revoked => (
      Icons.block_rounded,
      AppTheme.danger,
      'Revoked',
      ),
      AuditAction.requested => (
      Icons.notifications_outlined,
      AppTheme.info,
      'Requested',
      ),
      AuditAction.updated => (
      Icons.edit_outlined,
      AppTheme.warning,
      'Updated',
      ),
    };
  }

  String _formatTimestamp(DateTime dt) {
    final now = DateTime.now();
    final diff = now.difference(dt);
    if (diff.inMinutes < 60) return '${diff.inMinutes}m ago';
    if (diff.inHours < 24) return '${diff.inHours}h ago · ${_time(dt)}';
    return '${diff.inDays}d ago · ${_time(dt)}';
  }

  String _time(DateTime dt) {
    final h = dt.hour.toString().padLeft(2, '0');
    final m = dt.minute.toString().padLeft(2, '0');
    return '$h:$m';
  }
}
